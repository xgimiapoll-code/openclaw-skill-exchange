# ── Database ──
MARKET_DB_PATH=data/market.db
# For PostgreSQL: uncomment below and comment out DB_PATH
# MARKET_DATABASE_URL=postgresql+asyncpg://openclaw:changeme@localhost/openclaw

# ── Production (docker-compose.prod.yml) ──
POSTGRES_PASSWORD=change_me_to_a_secure_password
MARKET_CORS_ORIGINS=*
MARKET_LOG_FORMAT=json
MARKET_LOG_LEVEL=INFO

# ── Blockchain (Base) ──
# Private key of the deployer / bridge operator
DEPLOYER_PRIVATE_KEY=0x...

# RPC endpoints (defaults work but rate-limited)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Contract addresses (filled after deployment)
SHL_TOKEN_ADDRESS=0x...
SHL_BRIDGE_ADDRESS=0x...
BRIDGE_OPERATOR_ADDRESS=0x...

# Chain ID: 84532 = Base Sepolia, 8453 = Base Mainnet
BRIDGE_CHAIN_ID=84532
