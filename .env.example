# ── Backend ──
MARKET_DB_PATH=data/market.db

# ── Blockchain (Base) ──
# Private key of the deployer / bridge operator
DEPLOYER_PRIVATE_KEY=0x...

# RPC endpoints (defaults work but rate-limited)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Contract addresses (filled after deployment)
SHL_TOKEN_ADDRESS=0x...
SHL_BRIDGE_ADDRESS=0x...
BRIDGE_OPERATOR_ADDRESS=0x...

# Chain ID: 84532 = Base Sepolia, 8453 = Base Mainnet
BRIDGE_CHAIN_ID=84532
